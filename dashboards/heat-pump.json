                        "rawQuery": true,
                        "rawSql": "SELECT\n  $__timeGroupAlias(time, $__interval),\n  AVG(value) AS \"Frequency (Hz)\"\nFROM analog_readings\nWHERE $__timeFilter(time)\n  AND device_id = 'yutaki2016'\n  AND metric_name = 'svc_compressor_frequency'\nGROUP BY 1\nORDER BY 1",
