      "panel-7": {
        "kind": "Panel",
        "spec": {
          "id": 7,
          "title": "COP (hourly)",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "grafana-postgresql-datasource",
                      "version": "v0",
                      "datasource": {
                        "name": "${datasource}"
                      },
                      "spec": {
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": " WITH hourly AS (                                                                                                                                                                                                                                                                                                 \r\n    SELECT                               \r\n      bucket AT TIME ZONE 'Europe/Belgrade' AS bucket,                                                                                                                                                                                                                                                             \r\n      metric_name,\r\n      (max_val - first_val) + CASE WHEN last_val < first_val THEN last_val ELSE 0 END AS kwh                                                                                                                                                                                                                       \r\n    FROM analog_hourly                                         \r\n    WHERE $__timeFilter(bucket)\r\n      AND device_id = 'yutaki2016'\r\n      AND metric_name IN ('unit_capacity', 'unit_power_consumption')\r\n  )\r\n  SELECT\r\n    bucket AS time,\r\n    SUM(CASE WHEN metric_name = 'unit_capacity'          THEN kwh END) AS \"Thermal Energy Produced (kWh)\",\r\n    SUM(CASE WHEN metric_name = 'unit_power_consumption'  THEN kwh END) AS \"Electrical Energy Consumed (kWh)\",\r\n    CASE\r\n      WHEN SUM(CASE WHEN metric_name = 'unit_capacity'          THEN kwh END) = 0\r\n       AND SUM(CASE WHEN metric_name = 'unit_power_consumption'  THEN kwh END) > 0 THEN NULL\r\n      ELSE SUM(CASE WHEN metric_name = 'unit_capacity'          THEN kwh END) /\r\n           NULLIF(SUM(CASE WHEN metric_name = 'unit_power_consumption' THEN kwh END), 0)\r\n    END AS \"COP\"\r\n  FROM hourly\r\n  GROUP BY 1\r\n  ORDER BY 1\r\n",
                        "sql": {
                          "columns": [
                            {
                              "parameters": [],
                              "type": "function"
                            }
                          ],
                          "groupBy": [
                            {
                              "property": {
                                "type": "string"
                              },
                              "type": "groupBy"
                            }
                          ],
                          "limit": 50
                        }
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
