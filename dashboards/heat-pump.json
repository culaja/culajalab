                        "editorMode": "code",
                        "format": "time_series",
                        "rawQuery": true,
                        "rawSql": "SELECT\n  $__timeGroupAlias(time, $__interval),\n  AVG(CASE WHEN metric_name = 'outdoor_ambient_temperature'          THEN value END) AS \"Outdoor (°C)\",\n  AVG(CASE WHEN metric_name = 'water_inlet_temperature'              THEN value END) AS \"Water Inlet (°C)\",\n  AVG(CASE WHEN metric_name = 'water_outlet_temperature'             THEN value END) AS \"Water Outlet (°C)\",\n  AVG(CASE WHEN metric_name = 'svc_water_temp_setting' THEN value END) AS \"Setpoint (°C)\"\nFROM analog_readings\nWHERE $__timeFilter(time)\n  AND device_id = 'yutaki2016'\n  AND metric_name IN (\n    'outdoor_ambient_temperature',\n    'water_inlet_temperature',\n    'water_outlet_temperature',\n    'svc_water_temp_setting'\n  )\nGROUP BY 1\nORDER BY 1",
                        "sql": {
                          "columns": [
                            {
                              "parameters": [],
                              "type": "function"
                            }
                          ],
                          "groupBy": [
                            {
                              "property": {
