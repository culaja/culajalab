{
  "Mqtt": {
    "Host": null,
    "Port": 1883
  },
  "Devices": [
    {
      "Mac": null,
      "Model": "LYWSD03MMC (PVVX)",
      "Manufacturer": "Xiaomi",
      "StateTopic": "rumenka/sensor/{mac}/state",
      "Sensors": [
        {
          "Name": "Temperature",
          "DeviceClass": "temperature",
          "UnitOfMeasurement": "°C",
          "ValueTemplate": "{{ value_json.temperature }}",
          "StateClass": "measurement"
        },
        {
          "Name": "Humidity",
          "DeviceClass": "humidity",
          "UnitOfMeasurement": "%",
          "ValueTemplate": "{{ value_json.humidity }}",
          "StateClass": "measurement"
        },
        {
          "Name": "Battery",
          "DeviceClass": "battery",
          "UnitOfMeasurement": "%",
          "ValueTemplate": "{{ value_json.battery }}",
          "StateClass": "measurement"
        },
        {
          "Name": "RSSI",
          "DeviceClass": "signal_strength",
          "UnitOfMeasurement": "dBm",
          "ValueTemplate": "{{ value_json.rssi }}",
          "StateClass": "measurement"
        }
      ]
    }
  ],
  "Climates": [
    {
      "Name": "Rumenka Thermostat",
      "UniqueId": "hitachi_yutaki_circuit1",
      "Manufacturer": "Hitachi",
      "Model": "Yutaki 2016",
      "CurrentTemperatureTopic": "rumenka/hitachi/yutaki2016/circuit1",
      "CurrentTemperatureTemplate": "{{ value_json.status_circuit1_thermostat_room_temperature }}",
      "TemperatureCommandTopic": "rumenka/hitachi/yutaki2016/control/circuit1_thermostat_setpoint",
      "TemperatureStateTopic": "rumenka/hitachi/yutaki2016/circuit1",
      "TemperatureStateTemplate": "{{ value_json.status_circuit1_thermostat_setpoint }}",
      "ModeCommandTopic": "",
      "ModeCommandTemplate": "",
      "ModeStateTopic": "rumenka/hitachi/yutaki2016/unit",
      "ModeStateTemplate": "{{ 'heat' if value_json.status_unit_run_stop == 'Run' else 'off' }}",
      "Modes": [ "off", "heat" ],
      "MinTemp": 16,
      "MaxTemp": 30,
      "TempStep": 0.5
    }
  ],
  "Registrar": {
    "SensorExpirySeconds": 300
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
